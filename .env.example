# HealthGuard AI — Environment Variables
# Copy to .env and fill in your values

# ── FREE API Keys (no credit card required) ───────────────────────────────────

# 1. Google Gemini — Synthesizer (main report generation)
#    Get free key at: https://aistudio.google.com  → "Get API key"
#    Free tier: 1,500 requests/day, Gemini 2.0 Flash, no credit card
GOOGLE_API_KEY=your_google_api_key_here

# 2. Groq — Critic Agent (fast quality evaluation)
#    Get free key at: https://console.groq.com → "Create API Key"
#    Free tier: 1,000 req/day, Llama 3.3 70B at 700+ tokens/sec, no credit card
GROQ_API_KEY=your_groq_api_key_here

# 3. LangSmith — Observability (optional, free tier available)
#    Get free key at: https://smith.langchain.com
#    Leave blank to disable tracing during development
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=healthguard-ai

# ── Services ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Model paths ───────────────────────────────────────────────────────────────
VISION_MODEL_WEIGHTS_PATH=ml/vision/weights/densenet121_chestxray14.pth
FAISS_INDEX_PATH=ml/rag/indexes/faiss_medical
BM25_CORPUS_PATH=ml/rag/indexes/bm25_corpus.json

# ── Output dirs ───────────────────────────────────────────────────────────────
GRADCAM_OUTPUT_DIR=/tmp/healthguard/gradcam
UPLOAD_DIR=/tmp/healthguard/uploads

# ── Azure (for deployment) ────────────────────────────────────────────────────
AZURE_CONTAINER_REGISTRY=healthguardacr
AZURE_RESOURCE_GROUP=healthguard-rg
